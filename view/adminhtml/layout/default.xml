<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="before.body.end">
            <block name="melios.image.editor"
                   class="Melios\PageBuilder\Block\Adminhtml\ImageEditor"
                   template="Melios_PageBuilder::image_editor.phtml">
                <arguments>
                    <argument name="imageDetailsUrl" xsi:type="url" path="media_gallery/image/details"/>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
